# This file keeps the data/ directory tracked in git.
# The actual database and FAISS index are excluded via .gitignore because:
#   - jan_aadhaar_demo.sqlite  : generated by --seed-demo-db or --import-excel
#   - schema.faiss             : generated by --build-index
#   - schema_metadata.json     : generated by --build-index
#
# To set up locally after cloning:
#   python app.py --seed-demo-db        (creates the demo SQLite database)
#   python app.py --build-index         (builds the FAISS schema index)
#   OR
#   python app.py --import-excel dummy_dataset/Dummy_Data_Set.xlsx
